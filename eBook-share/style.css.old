*{margin: 0px;padding: 0px;}

body{
    min-width: 800px;
    background-color: rgb(245, 245, 245);
    background-image: url(../figure/share_background.jpg);
    background-attachment: fixed;
    background-repeat: no-repeat;
    background-size: cover;
}

#nav{
    width: 100%;
    height: 51px;
    box-shadow: 0px 2px 2px 0px;
    position: fixed;
    top: 0px;
    background-color: rgba(255, 255, 255, 0.801);
    background-size: cover;
    background-repeat: no-repeat;
}
#nav>span{
    display: block;
    margin-right: 20px;
    font-size: larger;
    height: 100%;
    line-height: 50px;
    float: right;
}

.cat{
    background-color: rgba(255, 255, 255, 0.582);
    margin-left: 20px;
    margin-right: 20px;
    border-radius: 10px;
    padding-bottom: 10px;
    border: 1px solid;
    box-shadow: 0px 2px 4px rgba(36, 36, 36, 0.548);
    margin-bottom: 20px;
    float: left;
}

.cat>h1{
    font-size: larger;
    border-bottom: 1px solid;
    padding: 10px 20px 10px 20px;
    font-weight: 200;
}
.cat>a{
    display: block;
    margin: 10px;
    height: 60px;
    border: 1px ;
    border-style: solid;
    box-shadow: 0px 2px 4px 0px gray;
    color: rgb(54, 54, 54);
    border-color: rgb(179, 179, 179);
    background-color: rgba(255, 255, 255, 0.856);
    border-radius: 5px;
    
}
.cat>a>img{
    height: 60px;
    margin: 10px;
    float: left;
}
.cat>a>p{
float: left;
margin-left: 10px;
line-height: 60px;
}

